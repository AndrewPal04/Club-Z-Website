# Copy this file to .env and fill in values before running the server.

# Secret used to sign session cookies. Use a long random string in production.
SESSION_SECRET=replace-with-a-long-random-secret

# Port the server listens on (default: 3000)
PORT=3000

# Path to the SQLite database file (default: clubz.db in the project root)
DB_PATH=./clubz.db

# Set to "production" in a deployed environment; controls secure cookies
NODE_ENV=development
